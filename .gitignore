# ============================================================
# .gitignore — Security: ensure no sensitive data is committed
# ============================================================

# API keys — NEVER commit these
.env

# Input PDF — may be copyrighted; share only the extracted output
input/*.pdf
input/*.PDF

# Local Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Extraction state (local only — users rebuild their own)
output/.extraction_state.json
output/.extraction_state.tmp

# Node / React
node_modules/
viewer/dist/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
